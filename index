        // 🌌 背景粒子與煙火引擎
        const bgCanvas = document.getElementById('bg-stars-canvas');
        const bgCtx = bgCanvas.getContext('2d');
        let bgStars = [];
        let effectParticles = []; 

        function resizeBgCanvas() {
            bgCanvas.width = window.innerWidth;
            bgCanvas.height = window.innerHeight;
            initBgStars();
        }

        function initBgStars() {
            bgStars = [];
            const starCount = Math.floor((bgCanvas.width * bgCanvas.height) / 8000);
            for (let i = 0; i < starCount; i++) {
                bgStars.push({
                    x: Math.random() * bgCanvas.width,
                    y: Math.random() * bgCanvas.height,
                    radius: Math.random() * 1.5 + 0.5,
                    opacity: Math.random(),
                    speed: Math.random() * 0.02 + 0.005
                });
            }
        }

        function triggerFireworksBurst(targetX, targetY, goldTheme = false) {
            const particleColors = goldTheme 
                ? ['#fbbf24', '#f59e0b', '#d97706', '#fef08a', '#ffffff', '#eab308'] 
                : ['#f43f5e', '#3b82f6', '#eab308', '#10b981', '#a855f7', '#06b6d4', '#f97316'];
            const count = goldTheme ? 60 : 45; 
            
            for (let i = 0; i < count; i++) {
                const angle = Math.random() * Math.PI * 2;
                const speed = Math.random() * (goldTheme ? 10 : 8) + 3;
                effectParticles.push({
                    x: targetX,
                    y: targetY,
                    vx: Math.cos(angle) * speed,
                    vy: Math.sin(angle) * speed - (Math.random() * 3), 
                    radius: Math.random() * 4 + 2,
                    color: particleColors[Math.floor(Math.random() * particleColors.length)],
                    opacity: 1,
                    decay: Math.random() * 0.02 + 0.015,
                    gravity: 0.12, 
                    friction: 0.985 
                });
            }
        }

        function animateBgStars() {
            bgCtx.clearRect(0, 0, bgCanvas.width, bgCanvas.height);
            
            bgStars.forEach(star => {
                star.opacity += star.speed;
                if (star.opacity > 1 || star.opacity < 0) {
                    star.speed = -star.speed;
                }
                bgCtx.fillStyle = `rgba(168, 85, 247, ${Math.max(0.1, star.opacity * 0.6)})`; 
                bgCtx.beginPath();
                bgCtx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
                bgCtx.fill();
            });

            effectParticles.forEach((p, pIdx) => {
                p.vx *= p.friction;
                p.vy *= p.friction;
                p.vy += p.gravity;
                p.x += p.vx;
                p.y += p.vy;
                p.opacity -= p.decay;

                if (p.opacity <= 0) {
                    effectParticles.splice(pIdx, 1);
                } else {
                    bgCtx.save();
                    bgCtx.globalAlpha = p.opacity;
                    bgCtx.shadowBlur = 10;
                    bgCtx.shadowColor = p.color;
                    bgCtx.fillStyle = p.color;
                    bgCtx.beginPath();
                    bgCtx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                    bgCtx.fill();
                    bgCtx.restore();
                }
            });

            requestAnimationFrame(animateBgStars);
        }

