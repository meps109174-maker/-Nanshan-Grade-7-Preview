        }

        function updateHPDisplay() {
            const hearts = "🛡️ ".repeat(player.hp) + "░ ".repeat(player.maxHp - player.hp);
            document.getElementById('game-hp-stars').innerText = hearts;
            if (player.hp === 1) {
                document.getElementById('game-hp-stars').className = "text-rose-500 animate-pulse text-base";
            } else {
                document.getElementById('game-hp-stars').className = "text-cyan-400 text-base";
            }
        }

        function updateWeaponBadge() {
            const badge = document.getElementById('game-weapon-badge');
            if (player.weapon === 'normal') {
                badge.innerText = "標準雷射";
                badge.className = "bg-cyan-500/20 text-cyan-300 border border-cyan-400/30 px-2 py-0.5 rounded text-[10px] font-black";
            } else if (player.weapon === 'spread') {
                badge.innerText = "三叉擴散雷射";
                badge.className = "bg-yellow-500/20 text-yellow-300 border border-yellow-400/30 px-2 py-0.5 rounded text-[10px] font-black animate-pulse";
            } else if (player.weapon === 'cannon') {
                badge.innerText = "重離子軌道砲";
                badge.className = "bg-red-500/20 text-red-300 border border-red-400/30 px-2 py-0.5 rounded text-[10px] font-black animate-pulse";
            }
        }

        function triggerShooterReward() {
            document.getElementById('screen-quiz').classList.add('hidden');
            
            const gameScreen = document.getElementById('screen-game');
            gameScreen.classList.remove('hidden');
            setTimeout(() => gameScreen.style.opacity = '1', 50);
            
            gameScore = 0;
            shooterTimeLeft = 30;
            bullets = [];
            enemyBullets = [];
            asteroids = [];
            powerups = [];
            particles = [];
            
            boss = null;
            bossSpawned = false;

            player.hp = 3;
            player.weapon = 'normal';
            updateHPDisplay();
            updateWeaponBadge();

            document.getElementById('game-score').innerText = gameScore;
            document.getElementById('game-timer').innerText = `${shooterTimeLeft}s`;
            document.getElementById('game-title-text').innerHTML = `<i class="fa-solid fa-shield-halved mr-1 text-cyan-400 animate-pulse"></i> 太空防禦戰 (一般空域)`;

            playSound('unlock');
            resizeCanvas();

            window.addEventListener('keydown', handleKeyDown);
            window.addEventListener('keyup', handleKeyUp);
            canvas.addEventListener('touchstart', handleTouchStart, { passive: true });
            canvas.addEventListener('touchmove', handleTouchMove, { passive: true });

            isShooterRunning = true;
            requestAnimationFrame(updateShooter);

            clearInterval(shooterTimer);
            shooterTimer = setInterval(() => {
                shooterTimeLeft--;
                document.getElementById('game-timer').innerText = `${shooterTimeLeft}s`;
                
                if (shooterTimeLeft === 15 && !bossSpawned) {
                    spawnBoss母艦();
                }

                if (shooterTimeLeft <= 0) {
                    endShooterGame();
                }
            }, 1000);
        }

        function spawnBoss母艦() {
            bossSpawned = true;
            playSound('boss-alert');
            document.getElementById('game-title-text').innerHTML = `<span class="text-rose-500 font-black animate-pulse uppercase tracking-wider"><i class="fa-solid fa-triangle-exclamation mr-1"></i> BOSS 來襲：星際母艦 <i class="fa-solid fa-radiation"></i></span>`;
            
            boss = {
                x: canvas.width / 2 - 40,
                y: -60,
                width: 80,
                height: 40,
                hp: 35,
                maxHp: 35,
                vx: 2,
                lastShot: 0
            };
        }

        function handleKeyDown(e) {
            keys[e.code] = true;
            if (e.code === 'Space') {
                e.preventDefault(); 
            }
        }
        function handleKeyUp(e) {
            keys[e.code] = false;
        }

        function handleTouchStart(e) {
            touchStartX = e.touches[0].clientX;
        }
        function handleTouchMove(e) {
            const touchX = e.touches[0].clientX;
            const diff = touchX - touchStartX;
            player.x += diff * 1.5; 
            touchStartX = touchX;

            if (player.x < 0) player.x = 0;
            if (player.x > canvas.width - player.width) player.x = canvas.width - player.width;
        }

        function createExplosion(x, y, color) {
            playSound('explode');
            for (let i = 0; i < 15; i++) {
                particles.push({
                    x: x,
                    y: y,
                    vx: (Math.random() - 0.5) * 8,
                    vy: (Math.random() - 0.5) * 8,
                    radius: Math.random() * 3.5 + 1.5,
                    alpha: 1,
                    decay: Math.random() * 0.04 + 0.02,
                    color: color
                });
            }
        }

        let lastShotTime = 0;
        function updateShooter(timestamp) {
            if (!isShooterRunning) return;

            ctx.fillStyle = '#020617';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            ctx.strokeStyle = 'rgba(6, 182, 212, 0.05)';
            ctx.lineWidth = 1;
            for (let i = 0; i < canvas.height; i += 40) {
                ctx.beginPath();
                ctx.moveTo(0, i);
                ctx.lineTo(canvas.width, i);
                ctx.stroke();
            }

            if (keys['ArrowLeft'] || keys['KeyA']) {
                player.x = Math.max(0, player.x - player.speed);
            }
            if (keys['ArrowRight'] || keys['KeyD']) {
                player.x = Math.min(canvas.width - player.width, player.x + player.speed);
            }

            if (timestamp - lastShotTime > 150) {
                if (player.weapon === 'normal') {
                    bullets.push({ x: player.x + player.width / 2 - 2, y: player.y, vx: 0, vy: -11, width: 4, height: 12, color: '#fb7185', power: 1 });
                    playSound('laser');
                } else if (player.weapon === 'spread') {
                    bullets.push({ x: player.x + player.width / 2 - 2, y: player.y, vx: 0, vy: -11, width: 4, height: 12, color: '#f59e0b', power: 1 });
                    bullets.push({ x: player.x + player.width / 2 - 6, y: player.y, vx: -3, vy: -10, width: 4, height: 12, color: '#f59e0b', power: 1 });
                    bullets.push({ x: player.x + player.width / 2 + 2, y: player.y, vx: 3, vy: -10, width: 4, height: 12, color: '#f59e0b', power: 1 });
                    playSound('laser');
                } else if (player.weapon === 'cannon') {
                    bullets.push({ x: player.x + player.width / 2 - 6, y: player.y, vx: 0, vy: -14, width: 12, height: 24, color: '#ef4444', power: 3 });
                    playSound('shock');
                }
                lastShotTime = timestamp;
            }

            ctx.fillStyle = '#22d3ee'; 
            ctx.beginPath();
            ctx.moveTo(player.x + player.width / 2, player.y);
            ctx.lineTo(player.x, player.y + player.height);
            ctx.lineTo(player.x + player.width, player.y + player.height);
            ctx.closePath();
            ctx.fill();
            
            ctx.fillStyle = '#f43f5e';
            ctx.fillRect(player.x + player.width / 2 - 4, player.y + player.height, 8, 4);

            bullets.forEach((bullet, index) => {
                bullet.x += bullet.vx;
                bullet.y += bullet.vy;
                ctx.fillStyle = bullet.color;
                ctx.fillRect(bullet.x, bullet.y, bullet.width, bullet.height);
                if (bullet.y < -20 || bullet.x < -10 || bullet.x > canvas.width + 10) {
                    bullets.splice(index, 1);
                }
            });

            if (boss) {
                boss.x += boss.vx;
                if (boss.x <= 10 || boss.x + boss.width >= canvas.width - 10) {
                    boss.vx = -boss.vx;
                }
                if (boss.y < 50) {
                    boss.y += 1.5;
                }

                if (timestamp - boss.lastShot > 600) {
                    enemyBullets.push({
                        x: boss.x + boss.width / 2 - 3,
                        y: boss.y + boss.height,
                        vx: (player.x + player.width/2 - (boss.x + boss.width/2)) / 80, 
                        vy: 4,
                        size: 6,
                        color: '#a855f7'
                    });
                    boss.lastShot = timestamp;
                }

                ctx.fillStyle = '#1e1b4b'; 
                ctx.fillRect(boss.x, boss.y, boss.width, boss.height - 10);
                ctx.fillStyle = '#818cf8'; 
                ctx.fillRect(boss.x + 10, boss.y + boss.height - 10, boss.width - 20, 10);
                
                ctx.fillStyle = '#f43f5e';
                ctx.beginPath();
                ctx.arc(boss.x + boss.width / 2, boss.y + boss.height / 2, 8, 0, Math.PI * 2);
                ctx.fill();

                const hpPercent = boss.hp / boss.maxHp;
                ctx.fillStyle = 'rgba(244, 63, 94, 0.2)';
                ctx.fillRect(boss.x - 10, boss.y - 15, boss.width + 20, 5);
                ctx.fillStyle = '#f43f5e';
                ctx.fillRect(boss.x - 10, boss.y - 15, (boss.width + 20) * hpPercent, 5);
            }

            enemyBullets.forEach((eb, ebIdx) => {
                eb.x += eb.vx;
                eb.y += eb.vy;
                ctx.fillStyle = eb.color;
                ctx.beginPath();
                ctx.arc(eb.x, eb.y, eb.size, 0, Math.PI * 2);
                ctx.fill();

                if (eb.y > canvas.height + 10) {
                    enemyBullets.splice(ebIdx, 1);
                }

                const distPlayer = Math.hypot((eb.x - (player.x + player.width / 2)), (eb.y - (player.y + player.height / 2)));
                if (distPlayer < eb.size + player.width / 2) {
                    enemyBullets.splice(ebIdx, 1);
                    damagePlayerShield();
                }
            });

            if (Math.random() < 0.045 && (!boss || Math.random() < 0.02)) {
                const rand = Math.random();
                if (rand < 0.70) {
                    asteroids.push({
                        type: 'normal',
                        x: Math.random() * (canvas.width - 30),
                        y: -30,
                        size: Math.random() * 20 + 15,
                        speed: Math.random() * 2 + 1.5,
                        color: `hsl(${Math.random() * 60 + 260}, 70%, 50%)` 
                    });
                } else {
                    asteroids.push({
                        type: 'comet',
                        x: Math.random() * (canvas.width - 20),
                        y: -30,
                        size: 14,
                        speed: Math.random() * 2 + 4, 
                        color: '#f43f5e'
                    });
                }
            }

            asteroids.forEach((ast, aIdx) => {
                ast.y += ast.speed;
                
                ctx.fillStyle = ast.color;
                ctx.beginPath();
                ctx.arc(ast.x + ast.size / 2, ast.y + ast.size / 2, ast.size / 2, 0, Math.PI * 2);
                ctx.fill();

                if (ast.y > canvas.height) {
                    asteroids.splice(aIdx, 1);
                    if (ast.type === 'comet') {
                        gameScore = Math.max(0, gameScore - 100);
                        document.getElementById('game-score').innerText = gameScore;
                    }
                }

                const distToPlayer = Math.hypot((ast.x + ast.size/2 - (player.x + player.width/2)), (ast.y + ast.size/2 - (player.y + player.height/2)));
                if (distToPlayer < (ast.size/2 + player.width/2 - 4)) {
                    createExplosion(ast.x + ast.size/2, ast.y + ast.size/2, ast.color);
                    asteroids.splice(aIdx, 1);
                    damagePlayerShield();
                }

                bullets.forEach((bullet, bIdx) => {
                    const dist = Math.hypot((bullet.x - (ast.x + ast.size / 2)), (bullet.y - (ast.y + ast.size / 2)));
                    if (dist < ast.size / 2 + 6) {
                        createExplosion(ast.x + ast.size / 2, ast.y + ast.size / 2, ast.color);
                        
                        if (Math.random() < 0.18) {
                            spawnPowerup(ast.x + ast.size/2, ast.y + ast.size/2);
                        }

                        asteroids.splice(aIdx, 1);
                        bullets.splice(bIdx, 1);
                        
                        const points = ast.type === 'comet' ? 250 : 100;
                        gameScore += points;
                        score += Math.floor(points / 2); 
                        
                        // 📊 計算隕石擊毀總量
                        totalAsteroidsSmashed++;

                        document.getElementById('global-score').innerText = score;
                        document.getElementById('game-score').innerText = gameScore;
                    }
                });
            });

            if (boss) {
                bullets.forEach((bullet, bIdx) => {
                    if (bullet.x > boss.x && bullet.x < boss.x + boss.width &&
                        bullet.y > boss.y && bullet.y < boss.y + boss.height) {
                        
                        bullets.splice(bIdx, 1);
                        boss.hp -= bullet.power;
                        createExplosion(bullet.x, bullet.y, '#f43f5e');

                        if (boss.hp <= 0) {
                            createExplosion(boss.x + boss.width/2, boss.y + boss.height/2, '#eab308');
                            createExplosion(boss.x + 20, boss.y + 10, '#f97316');
                            createExplosion(boss.x + 60, boss.y + 10, '#3b82f6');
                            
                            boss = null;
                            const bossBonus = 2500;
                            gameScore += bossBonus;
                            score += 1000; 
                            
                            // 📊 計算旗艦擊沉數量
                            totalBossesDestroyed++;

                            document.getElementById('global-score').innerText = score;
                            document.getElementById('game-score').innerText = gameScore;
                            
                            document.getElementById('game-title-text').innerHTML = `<span class="text-yellow-400 font-extrabold tracking-widest animate-bounce"><i class="fa-solid fa-crown mr-1"></i> 旗艦擊沉！獲得大幅積分加成</span>`;
                        }
                    }
                });
            }

            powerups.forEach((pu, puIdx) => {
                pu.y += 2.5; 
                
                ctx.save();
                ctx.shadowBlur = 12;
                ctx.shadowColor = pu.color;
                ctx.fillStyle = pu.color;
                ctx.beginPath();
                ctx.arc(pu.x, pu.y, 7, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();

                if (pu.y > canvas.height + 15) {
                    powerups.splice(puIdx, 1);
                }

                const distToPlayer = Math.hypot((pu.x - (player.x + player.width/2)), (pu.y - (player.y + player.height/2)));
                if (distToPlayer < (7 + player.width/2)) {
                    powerups.splice(puIdx, 1);
                    playSound('powerup');
                    applyPowerupEffect(pu.type);
                }
            });

            particles.forEach((p, pIdx) => {
                p.x += p.vx;
                p.y += p.vy;
                p.alpha -= p.decay;
                if (p.alpha <= 0) {
                    particles.splice(pIdx, 1);
                } else {
                    ctx.save();
                    ctx.globalAlpha = p.alpha;
                    ctx.fillStyle = p.color;
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.restore();
                }
            });

            requestAnimationFrame(updateShooter);
        }

        function spawnPowerup(x, y) {
            const rand = Math.random();
            let chosenType = 'spread';
            let color = '#fbbf24'; 
            
            if (rand < 0.4) {
                chosenType = 'spread';
            } else if (rand < 0.7) {
                chosenType = 'cannon';
                color = '#ef4444'; 
            } else {
                chosenType = 'shield';
                color = '#10b981'; 
            }

            powerups.push({ x: x, y: y, type: chosenType, color: color });
        }

        function applyPowerupEffect(type) {
            if (type === 'shield') {
                if (player.hp < player.maxHp) {
                    player.hp++;
                    updateHPDisplay();
                }
            } else {
                player.weapon = type;
                updateWeaponBadge();
            }
        }

        function damagePlayerShield() {
            playSound('wrong');
            triggerScreenShake();
            player.hp--;
            updateHPDisplay();

            if (player.hp <= 0) {
                endShooterGame();
            }
        }

        function endShooterGame() {
            isShooterRunning = false;
            clearInterval(shooterTimer);

            window.removeEventListener('keydown', handleKeyDown);
            window.removeEventListener('keyup', handleKeyUp);
            canvas.removeEventListener('touchstart', handleTouchStart);
            canvas.removeEventListener('touchmove', handleTouchMove);

            document.getElementById('screen-game').classList.add('hidden');
            document.getElementById('screen-quiz').classList.remove('hidden');

            proceedToNextQuiz();
        }


        // 📚 動態字典清單
        function renderDictionary() {
            const grid = document.getElementById('quick-dict-grid');
            grid.innerHTML = '';

            quizDB.forEach(item => {
                const card = document.createElement('div');
                card.className = "bg-slate-900 border border-slate-950 p-4 rounded-xl flex items-center justify-between gap-3 shadow-md";
                card.innerHTML = `
                    <div>
                        <div class="flex items-center gap-2">
                            <strong class="text-sm font-extrabold text-slate-100">${item.word}</strong>
                        </div>
                        <p class="text-xs text-slate-400 leading-relaxed mt-1">${item.explain}</p>
                    </div>
                    <button onclick="speakEng('${item.word}')" class="w-8 h-8 rounded-full bg-slate-950 text-slate-400 hover:text-purple-400 flex items-center justify-center shrink-0 border border-slate-900 transition-colors">
                        <i class="fa-solid fa-volume-high text-xs"></i>
                    </button>
                `;
                grid.appendChild(card);
            });
        }
    </script>
</body>
</html>

