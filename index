            updateStatsUI();

            const prefCount = localStorage.getItem(PREF_COUNT_KEY);
            if (prefCount) {
                selectedCount = parseInt(prefCount, 10);
            } else {
                selectedCount = 41; 
            }
            updateQuestionCountUI();
        }

