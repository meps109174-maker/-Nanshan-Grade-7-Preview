        function handleOptionSelect(chosenIdx, event) {
            clearInterval(timer);
            const qData = shuffledQuiz[currentIdx];
            const isCorrect = (chosenIdx === qData.answer);
            
            document.getElementById('options-panel').classList.add('pointer-events-none');
            const buttons = document.getElementById('options-panel').getElementsByTagName('button');

            qData.options.forEach((opt, i) => {
                const btn = buttons[i];
                btn.disabled = true;
                if (i === qData.answer) {
                    btn.className = "w-full text-left p-5 sm:p-6 rounded-2xl flex items-center justify-between font-bold text-base sm:text-lg bg-emerald-500 text-white border-2 border-emerald-300";
                    btn.querySelector('i').className = "fa-solid fa-circle-check text-white text-lg";
                } else if (i === chosenIdx) {
                    btn.className = "w-full text-left p-5 sm:p-6 rounded-2xl flex items-center justify-between font-bold text-base sm:text-lg bg-rose-600 text-white border-2 border-rose-400";
                    btn.querySelector('i').className = "fa-solid fa-circle-xmark text-white text-lg";
                } else {
                    btn.className = "w-full text-left p-5 sm:p-6 rounded-2xl flex items-center justify-between font-bold text-base sm:text-lg bg-slate-900 text-slate-600 border border-slate-950 opacity-40";
                    btn.querySelector('i').className = "fa-regular fa-circle text-transparent";
                }
            });

            let burstX = window.innerWidth / 2;
            let burstY = window.innerHeight / 2 - 100;
            if (event && event.clientX && event.clientY) {
                burstX = event.clientX;
                burstY = event.clientY;
            }

            showAnswerFeedback(isCorrect, false, burstX, burstY);
        }

        function handleTimeOut() {
            clearInterval(timer);
            document.getElementById('options-panel').classList.add('pointer-events-none');
            const qData = shuffledQuiz[currentIdx];
            const buttons = document.getElementById('options-panel').getElementsByTagName('button');

            qData.options.forEach((opt, i) => {
                const btn = buttons[i];
                btn.disabled = true;
                if (i === qData.answer) {
                    btn.className = "w-full text-left p-5 sm:p-6 rounded-2xl flex items-center justify-between font-bold text-base sm:text-lg bg-emerald-500 text-white border-2 border-emerald-300";
                    btn.querySelector('i').className = "fa-solid fa-circle-check text-white text-lg";
                } else {
                    btn.className = "w-full text-left p-5 sm:p-6 rounded-2xl flex items-center justify-between font-bold text-base sm:text-lg bg-slate-900 text-slate-600 border border-slate-950 opacity-40";
                    btn.querySelector('i').className = "fa-regular fa-circle text-transparent";
                }
            });

            showAnswerFeedback(false, true);
        }

        function showAnswerFeedback(isCorrect, isTimeout = false, burstX = null, burstY = null) {
            const feedbackCard = document.getElementById('feedback-card');
            const badgeIcon = document.getElementById('feedback-badge-icon');
            const title = document.getElementById('feedback-title');
            const qData = shuffledQuiz[currentIdx];

            feedbackCard.classList.remove('hidden');
            setTimeout(() => feedbackCard.style.opacity = '1', 50);
            lastAnsResult = isCorrect;

            document.getElementById('feedback-sentence-en').innerHTML = qData.sentenceEn;
            document.getElementById('feedback-sentence-zh').innerText = qData.sentenceZh;
            document.getElementById('feedback-rationale-text').innerText = qData.explain;

            // 📊 戰績反應反應速度記錄 (20秒減去剩餘時間)
            const reactionTime = 20 - timeLeft;
            sessionTimeTrack.push(reactionTime);

            if (isCorrect) {
                correctCount++;
                streak++;
                ticketsEarned++; 

                const multiplier = Math.min(2.0, 1.0 + (streak * 0.1)).toFixed(1);
                
                if (streak >= 2) {
                    playSound('combo', streak);
                } else {
                    playSound('correct');
                }

                triggerSuccessPulse();
                if (burstX !== null && burstY !== null) {
                    triggerFireworksBurst(burstX, burstY);
                    triggerFireworksBurst(window.innerWidth / 2, 80);
                } else {
                    triggerFireworksBurst(window.innerWidth / 2, window.innerHeight / 2);
                }
                
                const speedBonus = timeLeft * 40;
                const baseGained = 1000 + speedBonus;
                const finalGained = Math.floor(baseGained * parseFloat(multiplier));
                score += finalGained;

                badgeIcon.className = "w-8 h-8 rounded-full bg-emerald-500/10 text-emerald-400 flex items-center justify-center text-sm border border-emerald-500/20";
                badgeIcon.innerHTML = `<i class="fa-solid fa-check"></i>`;
                title.innerText = `搶答成功！ +${finalGained} 分 (倍率 ${multiplier}x)`;
                title.className = "font-black text-emerald-400 text-lg";

                const multiplierTag = document.getElementById('multiplier-tag');
                multiplierTag.innerText = `${multiplier}x`;
                if (parseFloat(multiplier) >= 1.5) {
                    multiplierTag.className = "bg-red-500 text-white px-1.5 py-0.5 rounded text-[9px] font-black leading-none animate-bounce";
                } else {
                    multiplierTag.className = "bg-orange-500 text-slate-950 px-1.5 py-0.5 rounded text-[9px] font-black leading-none";
                }

                speakEng(qData.sentenceEnPlain);

            } else {
                playSound('wrong');
                triggerScreenShake();
                streak = 0; 

                // 📊 錯題弱點分析記錄
                if (!sessionWrongWords.some(item => item.word === qData.word)) {
                    sessionWrongWords.push({
                        word: qData.word,
                        explain: qData.explain
                    });
                }

                badgeIcon.className = "w-8 h-8 rounded-full bg-rose-500/10 text-rose-400 flex items-center justify-center text-sm border border-rose-500/20";
                badgeIcon.innerHTML = `<i class="fa-solid fa-xmark"></i>`;
                title.innerText = isTimeout ? "搶答逾時了！" : "搶答失敗，再接再厲！";
                title.className = "font-black text-rose-400 text-lg";
            }

            document.getElementById('global-score').innerText = score;
            
            const streakBadge = document.getElementById('streak-badge');
            if (streak >= 1) {
                streakBadge.classList.remove('hidden');
                document.getElementById('streak-count').innerText = streak;
            } else {
                streakBadge.classList.add('hidden');
            }

            saveCurrentProgress();
            updateTicketDisplay();
        }

