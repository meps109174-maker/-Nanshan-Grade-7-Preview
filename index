        // 載入當前題目
        function loadQuestion() {
            timeLeft = 20;
            document.getElementById('time-left').innerText = `${timeLeft}s`;
            document.getElementById('time-left').className = "font-orbitron font-extrabold text-lg text-rose-400";
            
            const feedbackCard = document.getElementById('feedback-card');
            feedbackCard.classList.add('hidden');
            feedbackCard.style.opacity = '0'; 
            
            document.getElementById('options-panel').classList.remove('pointer-events-none', 'opacity-50');

            const qData = shuffledQuiz[currentIdx];
            document.getElementById('quiz-index-text').innerText = `${currentIdx + 1} / ${shuffledQuiz.length}`;
            document.getElementById('question-prompt').innerText = qData.question;

            qData.options.forEach((opt, i) => {
                const btnText = document.getElementById(`opt-text-${i}`);
                btnText.innerText = opt;
                const btn = btnText.closest('button');
                btn.className = getBtnDefaultClass(i);
                btn.disabled = false;
                
                const icon = btn.querySelector('i');
                if (i === 2) { 
                    icon.className = "fa-regular fa-circle text-black/20 text-lg";
                } else {
                    icon.className = "fa-regular fa-circle text-white/40 text-lg";
                }
            });

            saveCurrentProgress();

            clearInterval(timer);
            timer = setInterval(() => {
                timeLeft--;
                document.getElementById('time-left').innerText = `${timeLeft}s`;
                playSound('tick');
                
                if (timeLeft <= 5) {
                    document.getElementById('time-left').className = "font-orbitron font-extrabold text-xl text-red-500 animate-bounce";
                }

                if (timeLeft <= 0) {
                    clearInterval(timer);
                    handleTimeOut();
                }
            }, 1000);
        }

        function getBtnDefaultClass(idx) {
            const base = "kahoot-btn w-full text-left p-5 sm:p-6 rounded-2xl flex items-center justify-between font-bold text-base sm:text-lg shadow-lg ";
            if (idx === 0) return base + "bg-red-500 hover:bg-red-400 text-white shadow-red-500/10";
            if (idx === 1) return base + "bg-blue-500 hover:bg-blue-400 text-white shadow-blue-500/10";
            if (idx === 2) return base + "bg-yellow-500 hover:bg-yellow-400 text-slate-950 shadow-yellow-500/10";
            return base + "bg-green-500 hover:bg-green-400 text-white shadow-green-500/10";
        }

