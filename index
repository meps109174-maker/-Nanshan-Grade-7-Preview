        // 💾 恢復存檔對話框控制
        function checkSavedSession() {
            const saved = localStorage.getItem(SESSION_KEY);
            if (saved) {
                try {
                    const sessionData = JSON.parse(saved);
                    if (sessionData && sessionData.currentIdx > 0 && sessionData.currentIdx < sessionData.shuffledQuiz.length) {
                        document.getElementById('restore-progress').innerText = `${sessionData.currentIdx + 1} / ${sessionData.shuffledQuiz.length}`;
                        const modal = document.getElementById('modal-restore-session');
                        modal.classList.remove('hidden');
                        modal.classList.add('flex');
                        setTimeout(() => modal.classList.remove('opacity-0'), 50);
                        return true;
                    }
                } catch(e) {
                    console.log("時空存檔數據損毀，已自動清理。");
                    localStorage.removeItem(SESSION_KEY);
                }
            }
            return false;
        }

        function acceptSavedSession() {
            const saved = localStorage.getItem(SESSION_KEY);
            if (saved) {
                try {
                    const sessionData = JSON.parse(saved);
                    shuffledQuiz = sessionData.shuffledQuiz;
                    currentIdx = sessionData.currentIdx;
                    score = sessionData.score;
                    streak = sessionData.streak;
                    correctCount = sessionData.correctCount;
                    ticketsEarned = sessionData.ticketsEarned;
                    unlockedGamesCount = sessionData.unlockedGamesCount;

                    // 📊 同步恢復本局統計數據
                    sessionStartTime = sessionData.sessionStartTime || Date.now();
                    sessionTimeTrack = sessionData.sessionTimeTrack || [];
                    sessionWrongWords = sessionData.sessionWrongWords || [];
                    totalAsteroidsSmashed = sessionData.totalAsteroidsSmashed || 0;
                    totalBossesDestroyed = sessionData.totalBossesDestroyed || 0;

                    closeRestoreModal();
                    document.getElementById('screen-start').classList.add('hidden');
                    
                    document.getElementById('global-score').innerText = score;
                    if (streak >= 1) {
                        document.getElementById('streak-badge').classList.remove('hidden');
                        document.getElementById('streak-count').innerText = streak;
                    } else {
                        document.getElementById('streak-badge').classList.add('hidden');
                    }
                    updateTicketDisplay();

                    const quizScreen = document.getElementById('screen-quiz');
                    quizScreen.classList.remove('hidden');
                    quizScreen.style.opacity = '1';

                    playSound('unlock');
                    loadQuestion();
                } catch(e) {
                    rejectSavedSession();
                }
            }
        }

        function rejectSavedSession() {
            localStorage.removeItem(SESSION_KEY);
            closeRestoreModal();
