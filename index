        // 🟢 進入全螢幕並執行 3, 2, 1 倒數
        function requestStart() {
            const docElm = document.documentElement;
            if (docElm.requestFullscreen) {
                docElm.requestFullscreen().catch(err => console.log("無法全螢幕:", err));
            } else if (docElm.webkitRequestFullscreen) {
                docElm.webkitRequestFullscreen().catch(err => console.log("無法全螢幕:", err));
            }

            document.getElementById('screen-start').classList.add('hidden');
            
            runStartCountdown(() => {
                recordNewAttempt();
                startQuizTerm();
            });
        }

        // 🎬 經典 3, 2, 1, GO! 倒數計時邏輯
        function runStartCountdown(callback) {
            const overlay = document.getElementById('screen-countdown');
            const numberEl = document.getElementById('countdown-number');
            overlay.classList.remove('hidden');
            overlay.style.opacity = '1';

            let count = 3;
            numberEl.innerText = count;
            
            numberEl.className = "text-8xl sm:text-9xl font-black text-purple-400 font-orbitron scale-[2] opacity-0 transition-all duration-300 transform";
            
            setTimeout(() => {
                numberEl.classList.remove('scale-[2]', 'opacity-0');
                numberEl.classList.add('scale-100', 'opacity-100');
                playSound('tick');
            }, 50);

            const countdownTimer = setInterval(() => {
                count--;
                if (count > 0) {
                    numberEl.innerText = count;
                    numberEl.className = "text-8xl sm:text-9xl font-black text-purple-400 font-orbitron scale-[2] opacity-0";
                    setTimeout(() => {
                        numberEl.classList.remove('scale-[2]', 'opacity-0');
                        numberEl.classList.add('scale-100', 'opacity-100');
                        playSound('tick');
                    }, 50);
                } else if (count === 0) {
                    numberEl.innerText = "GO!";
                    numberEl.className = "text-8xl sm:text-9xl font-black text-cyan-400 font-orbitron scale-[2.5] opacity-0";
                    setTimeout(() => {
                        numberEl.classList.remove('scale-[2.5]', 'opacity-0');
                        numberEl.classList.add('scale-100', 'opacity-100');
                        playSound('tick-high');
                    }, 50);
                } else {
                    clearInterval(countdownTimer);
                    overlay.style.opacity = '0';
                    setTimeout(() => {
                        overlay.classList.add('hidden');
                        callback();
                    }, 300);
                }
            }, 1000);
        }

