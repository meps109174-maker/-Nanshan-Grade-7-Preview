            const alertEl = document.getElementById('landscape-alert');
            if (window.innerHeight > window.innerWidth && window.innerWidth < 768) {
                if (sessionStorage.getItem('landscapeDismissed') !== 'true') {
                    alertEl.classList.remove('hidden');
                    alertEl.classList.add('flex');
                    setTimeout(() => alertEl.style.opacity = '1', 50);
                }
            } else {
                alertEl.style.opacity = '0';
                setTimeout(() => {
                    alertEl.classList.add('hidden');
                    alertEl.classList.remove('flex');
                }, 300);
            }
        }

        function dismissLandscapeAlert() {
            sessionStorage.setItem('landscapeDismissed', 'true');
            const alertEl = document.getElementById('landscape-alert');
            alertEl.style.opacity = '0';
            setTimeout(() => {
                alertEl.classList.add('hidden');
                alertEl.classList.remove('flex');
            }, 300);
        }

